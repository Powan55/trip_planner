rules_version = '2';

// Capability-token trips: each trip lives at trips/{tripId}, where tripId is a
// high-entropy unguessable secret (crypto.randomUUID(), minted client-side).
// Whoever HOLDS the token has full read+write on that trip's document tree —
// a capability-link model ("anyone with the link can edit"). There is NO
// per-user check: request.auth is never read; Firebase Auth is not required.
//
// The model rests on tripId being unguessable and unenumerable, so listing the
// top-level trips collection is explicitly denied. Collection-group queries
// across all trips are denied by omission (no rule grants them).
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny discovering trips by listing the top-level collection.
    match /trips {
      allow list: if false;
    }

    // A single known trip and everything under it: full read+write to anyone
    // who has the tripId. No request.auth check.
    match /trips/{tripId}/{document=**} {
      allow get, list, write: if true;
    }
  }
}
