# Firebase web config for OPTIONAL cross-friend itinerary sync.
#
# Copy this file to `.env.local` and fill the values from the Firebase console
# (Project settings > General > Your apps > SDK setup and configuration) to enable
# cross-friend sync. Leave it absent for LOCAL-ONLY mode: with no config the app is
# dormant — it builds and behaves exactly as a localStorage-only client.
#
# These values are PUBLIC by design (a Firebase web config is not a secret; server-side
# Security Rules are the real gate), but real values still belong in `.env.local`
# (git-ignored) or in CI secrets, NOT committed to source. Only this `.example` with
# empty placeholders is committed. (`.env.local` and `.env*.local` are git-ignored at
# the repo root.)

# Firebase Web API key (names the project; not a secret).
NEXT_PUBLIC_FIREBASE_API_KEY=
# Auth domain, e.g. your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# Firebase project id, e.g. your-project-id
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Cloud Storage bucket, e.g. your-project.appspot.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# Cloud Messaging sender id (numeric).
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Firebase app id, e.g. 1:1234567890:web:abcdef
NEXT_PUBLIC_FIREBASE_APP_ID=

# Shared trip id (the friends group shares one trip). Optional; defaults to nepal-japan-2026.
NEXT_PUBLIC_TRIP_ID=nepal-japan-2026
